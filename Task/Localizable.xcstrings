    "“%@” and all its groups, tags, and tasks will be removed." : {
      "comment" : "Message shown when confirming deletion of a board. The argument is the board's title.",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@”及其所有分组、标签和任务都将被移除。"
          }
        }
      }
    },
    "“%@” will be removed from every task it's applied to." : {
      "comment" : "A confirmation sheet that lets the user delete a tag. The argument is the name of the tag to be deleted.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@”将从应用此标签的所有任务中移除。"
          }
        }
      }
    },
    "“%@” will be removed. Its tasks will move to the first remaining status." : {
      "comment" : "Message shown in StatusPickerSheet when confirming deletion of a named status. The argument is the status name.",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@”将被移除。其中的任务将移至第一个剩余状态。"
          }
        }
      }
    },
