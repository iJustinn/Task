// Code signing team for the Task and TaskWidgetExtension targets.
//
// Contributors building their own copy should either edit this file with their
// Apple Developer Team ID or override locally by creating Config/Signing.local.xcconfig
// (gitignored) with `DEVELOPMENT_TEAM = ABC1234567` — the `#include?` below picks
// it up automatically if present.

DEVELOPMENT_TEAM = U6KN3BQL72
DERIVE_MACCATALYST_PRODUCT_BUNDLE_IDENTIFIER = NO
PRODUCT_BUNDLE_IDENTIFIER[sdk=macosx*] = com.ijustin.task

#include? "Signing.local.xcconfig"
