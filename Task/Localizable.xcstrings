    },
    "Default Status" : {
      "comment" : "A title for a sheet that allows the user to select a default status.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "默认状态"
          }
        }
      }
    },
    "Default Status sets which group new tasks on that board land in. Falls back to the first group if your choice is later deleted. Card Order controls how cards sort inside every group on that board — Manual (drag), Title (alphabetical), or Date (smart)." : {
      "extractionState" : "manual",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "默认状态决定该看板上新任务会进入哪个分组。如果所选分组之后被删除，则回退到首个分组。卡片顺序控制该看板上每个分组内卡片的排序方式 — 手动（拖动）、标题（按字母）或日期（智能）。"
          }
        }
      }
    },
